#include <bits/stdc++.h>
using namespace std;
#define fr(i,n) for(int i=0;i<n;i++)
#define ll long long
 
vector<pair<int,int>> ans;
 
void f(int x,int y,int k){
    if(k<=0)return;
    if(k==1){
        //cout<<0<<" "<<0<<endl;
        ans.push_back({x,y});
        ans.push_back({x,y+1});
        return;
    }
    if(k==2){
        ans.push_back({x,y});
        ans.push_back({x,y+1});
        ans.push_back({x+1,y});
        return;
    }
    if(k==3){
        fr(i,k){
            //cout<<x<<" "<<y+i<<endl;
            ans.push_back({x,y+i});
        }
        return;
    }
    int c=0;
    for(int i=1;(i)*(i-1)/2<=k;i++){
        //cout<<x<<" "<<y+1<<endl;
        ans.push_back({x,y+i-1});
        c++;
    }
    f(x+501,y+501,k-((c)*(c-1)/2));
}
 
void solve(){
    ans.clear();
    int k;
    cin>>k;
    if(k==0){
        cout<<1<<endl;
        cout<<0<<" "<<0<<endl;
        return;
    }
    f(0,0,k);
    cout<<ans.size()<<endl;
    for(auto it:ans){
        cout<<it.first<<" "<<it.second<<endl;
    }
}
 
int main(){
    int t=1;
    cin >> t;
    while(t--) solve();
    return 0;
}